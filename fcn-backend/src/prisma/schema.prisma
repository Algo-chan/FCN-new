generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  patient
  doctor
  nurse
  rural_health_officer
  hospital_admin
  pharmacy_admin
  super_admin
}

enum UserStatus {
  pending
  active
  suspended
  rejected
}

enum ThemePreference {
  dark
  light
}

enum AvailabilityStatus {
  available
  in_session
  unavailable
}

enum HospitalStatus {
  active
  pending
  inactive
}

enum DataFeedType {
  manual
  api
}

enum AppointmentType {
  remote
  in_person
  nurse_visit
}

enum AppointmentStatus {
  pending
  confirmed
  scheduled
  in_session
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

enum PrescriptionStatus {
  active
  refill_due
  expired
  cancelled
  dispensed
}

enum MessageType {
  text
  file
  system
}

enum PharmacyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum RefillStatus {
  PENDING
  APPROVED
  DECLINED
}

model User {
  id               String          @id @default(uuid()) @db.Uuid
  full_name        String
  email            String?         @unique
  phone            String?         @unique
  password_hash    String?
  role             Role
  status           UserStatus      @default(pending)
  email_verified   Boolean         @default(false)
  phone_verified   Boolean         @default(false)
  fcm_token        String?
  theme_preference ThemePreference @default(dark)
  rejection_reason String?
  suspended_reason String?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  last_login_at    DateTime?

  patient_profile             PatientProfile?
  doctor_profile              DoctorProfile?       @relation("DoctorUser")
  nurse_profile               NurseProfile?
  approved_doctors            DoctorProfile[]      @relation("DoctorApprover")
  approved_nurses             NurseProfile[]       @relation("NurseApprover")
  patient_appointments        Appointment[]        @relation("PatientAppointments")
  doctor_appointments         Appointment[]        @relation("DoctorAppointments")
  nurse_appointments          Appointment[]        @relation("NurseAppointments")
  cancelled_appointments      Appointment[]        @relation("CancelledAppointments")
  patient_vitals              PatientVital[]       @relation("PatientVitals")
  recorded_vitals             PatientVital[]       @relation("RecordedVitals")
  patient_prescriptions       Prescription[]       @relation("PatientPrescriptions")
  doctor_prescriptions        Prescription[]       @relation("DoctorPrescriptions")
  sent_messages               Message[]            @relation("SentMessages")
  received_messages           Message[]            @relation("ReceivedMessages")
  notifications               Notification[]
  patient_consultation_ratings ConsultationRating[] @relation("PatientRatings")
  doctor_consultation_ratings  ConsultationRating[] @relation("DoctorRatings")
  hospital_admin_profiles      HospitalAdminProfile[]
  created_hospital_admins      HospitalAdminProfile[] @relation("CreatedHospitalAdmins")
  pharmacy_admin_profiles      PharmacyAdminProfile[]
  created_pharmacy_admins      PharmacyAdminProfile[] @relation("CreatedPharmacyAdmins")
  patient_refill_requests      RefillRequest[]        @relation("PatientRefillRequests")
  doctor_refill_requests       RefillRequest[]        @relation("DoctorRefillRequests")
  dispense_records             DispenseRecord[]
  symptom_assessments          SymptomAssessment[]
  doctor_notes                 DoctorNote[]         @relation("DoctorNotes")
  patient_notes                DoctorNote[]         @relation("PatientNotes")

  activity_logs ActivityLog[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  actor_id    String   @db.Uuid
  actor_role  String
  action      String
  target_type String?
  target_id   String?
  target_name String?
  details     Json?
  ip_address  String?
  created_at  DateTime @default(now())

  actor User @relation(fields: [actor_id], references: [id], onDelete: Restrict)

  @@index([actor_id, created_at])
  @@index([action, created_at])
  @@index([created_at])
  @@map("activity_logs")
}

model PatientProfile {
  user_id                 String    @id @db.Uuid
  date_of_birth           DateTime?
  blood_type              String?
  weight_kg               Decimal?  @db.Decimal(5, 2)
  height_cm               Decimal?  @db.Decimal(5, 2)
  chronic_conditions      String[]
  known_allergies         String?
  home_address            String?
  home_lat                Decimal?  @db.Decimal(10, 7)
  home_lng                Decimal?  @db.Decimal(10, 7)
  emergency_contact_name  String?
  emergency_contact_phone String?
  onboarding_completed    Boolean   @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model DoctorProfile {
  user_id                String             @id @db.Uuid
  license_number         String             @unique
  specialty              String
  hospital_id            String?            @db.Uuid
  availability_status    AvailabilityStatus @default(unavailable)
  bio                    String?
  rating_average         Decimal            @default(0) @db.Decimal(3, 2)
  rating_count           Int                @default(0)
  years_experience       Int
  consultation_fee_etb   Decimal            @default(50) @db.Decimal(10, 2)
  photo_url              String?
  photo_public_id        String?
  available_since        DateTime?
  approved_at            DateTime?
  approved_by            String?            @db.Uuid

  user      User      @relation("DoctorUser", fields: [user_id], references: [id], onDelete: Cascade)
  hospital  Hospital? @relation(fields: [hospital_id], references: [id], onDelete: SetNull)
  approver  User?     @relation("DoctorApprover", fields: [approved_by], references: [id], onDelete: SetNull)

  @@map("doctor_profiles")
}

model NurseProfile {
  user_id        String    @id @db.Uuid
  license_number String    @unique
  coverage_zone  String
  years_experience Int    @default(0)
  approved_at    DateTime?
  approved_by    String?   @db.Uuid

  user     User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  approver User? @relation("NurseApprover", fields: [approved_by], references: [id], onDelete: SetNull)

  @@map("nurse_profiles")
}

model Hospital {
  id                   String         @id @default(uuid()) @db.Uuid
  name                 String
  location             String
  lat                  Decimal?       @db.Decimal(10, 7)
  lng                  Decimal?       @db.Decimal(10, 7)
  total_beds           Int            @default(0)
  occupied_beds        Int            @default(0)
  active_doctors_count Int            @default(0)
  avg_wait_minutes     Int            @default(0)
  specialties          String[]
  status               HospitalStatus @default(pending)
  data_feed_type       DataFeedType   @default(manual)
  last_updated_at      DateTime       @updatedAt

  doctors              DoctorProfile[]
  hospital_admin_profiles HospitalAdminProfile[]
  hospital_pharmacy_links HospitalPharmacyLink[]

  @@map("hospitals")
}

model HospitalAdminProfile {
  user_id     String   @id @db.Uuid
  hospital_id String   @db.Uuid
  created_by  String   @db.Uuid
  created_at  DateTime @default(now())

  user     User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  hospital Hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade)
  creator  User    @relation("CreatedHospitalAdmins", fields: [created_by], references: [id], onDelete: Restrict)

  @@map("hospital_admin_profiles")
}

model Appointment {
  id                  String            @id @default(uuid()) @db.Uuid
  patient_id          String            @db.Uuid
  doctor_id           String            @db.Uuid
  nurse_id            String?           @db.Uuid
  appointment_type    AppointmentType
  status              AppointmentStatus @default(pending)
  scheduled_at        DateTime
  duration_minutes    Int               @default(30)
  chief_complaint     String?
  platform_fee_etb    Decimal           @default(50) @db.Decimal(10, 2)

  payment_status      PaymentStatus     @default(unpaid)
  payment_tx_ref      String?           @unique
  chapa_checkout_url  String?
  reschedule_count    Int               @default(0)
  rescheduled_from    DateTime?
  cancellation_reason String?
  cancelled_by        String?           @db.Uuid
  cancelled_by_role   String?
  actual_start_time   DateTime?
  actual_end_time     DateTime?
  consultation_started_at DateTime?
  consultation_ended_at   DateTime?
  reminder_sent           Boolean           @default(false)
  completed_at            DateTime?
  follow_up_prescription_deadline DateTime?

  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  patient             User                        @relation("PatientAppointments", fields: [patient_id], references: [id], onDelete: Restrict)
  doctor              User                        @relation("DoctorAppointments", fields: [doctor_id], references: [id], onDelete: Restrict)
  nurse               User?                       @relation("NurseAppointments", fields: [nurse_id], references: [id], onDelete: SetNull)
  cancelled_by_user   User?                       @relation("CancelledAppointments", fields: [cancelled_by], references: [id], onDelete: SetNull)
  vitals              PatientVital[]
  prescriptions       Prescription[]
  consultation_rating ConsultationRating?
  reschedule_history  AppointmentRescheduleHistory[]
  payment_logs        PaymentLog[]
  messages            Message[]
  consultation_summary ConsultationSummary?
  visit_checklist     NurseVisitChecklist?
  doctor_notes        DoctorNote[]

  @@index([patient_id, scheduled_at])
  @@index([doctor_id, scheduled_at])
  @@index([payment_tx_ref])
  @@map("appointments")
}

model SystemSettings {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("system_settings")
}

model AppointmentRescheduleHistory {
  id              String   @id @default(uuid()) @db.Uuid
  appointment_id  String   @db.Uuid
  old_scheduled_at DateTime
  new_scheduled_at DateTime
  rescheduled_at  DateTime @default(now())
  rescheduled_by  String   @db.Uuid
  reason          String?

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)

  @@index([appointment_id])
  @@map("appointment_reschedule_history")
}

model PaymentLog {
  id              String       @id @default(uuid()) @db.Uuid
  appointment_id  String       @db.Uuid
  tx_ref          String
  amount          Decimal      @db.Decimal(10, 2)
  status          PaymentStatus
  chapa_response  Json?
  created_at      DateTime     @default(now())

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)

  @@index([appointment_id])
  @@index([tx_ref])
  @@map("payment_logs")
}

model PatientVital {
  id                     String   @id @default(uuid()) @db.Uuid
  patient_id             String   @db.Uuid
  recorded_by_user_id    String   @db.Uuid
  appointment_id         String?  @db.Uuid
  bp_systolic            Int?
  bp_diastolic           Int?
  blood_glucose_mg_dl    Decimal? @db.Decimal(6, 2)
  heart_rate_bpm         Int?
  temperature_celsius    Decimal? @db.Decimal(4, 2)
  spo2_percent           Decimal? @db.Decimal(5, 2)
  weight_kg              Decimal? @db.Decimal(5, 2)
  height_cm              Decimal? @db.Decimal(5, 2)
  bmi                    Decimal? @db.Decimal(4, 1)
  vital_source           String   @default("self")
  is_flagged             Boolean  @default(false)
  flagged_reasons        String[]
  notes                  String?
  recorded_at            DateTime @default(now())

  patient          User         @relation("PatientVitals", fields: [patient_id], references: [id], onDelete: Cascade)
  recorded_by_user User         @relation("RecordedVitals", fields: [recorded_by_user_id], references: [id], onDelete: Restrict)
  appointment      Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  @@index([patient_id, recorded_at])
  @@map("patient_vitals")
}

model Prescription {
  id             String             @id @default(uuid()) @db.Uuid
  rx_reference   String             @unique
  appointment_id String?            @db.Uuid
  patient_id     String             @db.Uuid
  doctor_id      String             @db.Uuid
  status         PrescriptionStatus @default(active)
  qr_hash        String             @unique
  notes          String?
  issued_at      DateTime           @default(now())
  expires_at     DateTime
  refill_count   Int                @default(0)
  max_refills    Int                @default(1)
  dispensed_at   DateTime?
  dispensed_by_pharmacy_id String?  @db.Uuid
  dispense_count Int                @default(0)

  appointment        Appointment?             @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  patient            User                     @relation("PatientPrescriptions", fields: [patient_id], references: [id], onDelete: Restrict)
  doctor             User                     @relation("DoctorPrescriptions", fields: [doctor_id], references: [id], onDelete: Restrict)
  medications        PrescriptionMedication[]
  dispense_records   DispenseRecord[]
  refill_requests    RefillRequest[]
  dispensed_pharmacy Pharmacy?                @relation(fields: [dispensed_by_pharmacy_id], references: [id], onDelete: SetNull)

  @@index([patient_id, status])
  @@map("prescriptions")
}

model PrescriptionMedication {
  id                String    @id @default(uuid()) @db.Uuid
  prescription_id   String    @db.Uuid
  drug_name         String
  strength          String
  form              String?
  instructions      String
  frequency_per_day Int       @default(1)
  reminder_times    String[]
  supply_days       Int
  is_ongoing        Boolean   @default(false)
  quantity          Int?
  reminder_enabled  Boolean   @default(true)
  last_reminder_sent DateTime?

  prescription Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)

  @@map("prescription_medications")
}

model PharmacyAdminProfile {
  user_id     String   @id @db.Uuid
  pharmacy_id String   @db.Uuid
  created_by  String   @db.Uuid
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacy_id], references: [id], onDelete: Cascade)
  creator  User     @relation("CreatedPharmacyAdmins", fields: [created_by], references: [id], onDelete: Restrict)

  @@map("pharmacy_admin_profiles")
}

model HospitalPharmacyLink {
  id          String   @id @default(uuid()) @db.Uuid
  hospital_id String   @db.Uuid
  pharmacy_id String   @db.Uuid
  created_at  DateTime @default(now())

  hospital Hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacy_id], references: [id], onDelete: Cascade)

  @@unique([hospital_id, pharmacy_id])
  @@map("hospital_pharmacy_links")
}

model DispenseRecord {
  id                   String   @id @default(uuid()) @db.Uuid
  prescription_id      String   @db.Uuid
  pharmacy_id          String   @db.Uuid
  dispensed_by         String   @db.Uuid
  dispensed_at         DateTime @default(now())
  notes                String?
  medications_dispensed String[]

  prescription Prescription @relation(fields: [prescription_id], references: [id], onDelete: Restrict)
  pharmacy     Pharmacy     @relation(fields: [pharmacy_id], references: [id], onDelete: Restrict)
  dispensed_by_user User    @relation(fields: [dispensed_by], references: [id], onDelete: Restrict)

  @@index([prescription_id])
  @@index([pharmacy_id])
  @@map("dispense_records")
}

model RefillRequest {
  id                  String       @id @default(uuid()) @db.Uuid
  prescription_id     String       @db.Uuid
  patient_id          String       @db.Uuid
  doctor_id           String       @db.Uuid
  status              RefillStatus @default(PENDING)
  patient_note        String?
  doctor_note         String?
  new_prescription_id String?
  requested_at        DateTime     @default(now())
  responded_at        DateTime?

  prescription Prescription @relation(fields: [prescription_id], references: [id], onDelete: Restrict)
  patient      User         @relation("PatientRefillRequests", fields: [patient_id], references: [id], onDelete: Restrict)
  doctor       User         @relation("DoctorRefillRequests", fields: [doctor_id], references: [id], onDelete: Restrict)

  @@index([prescription_id])
  @@index([doctor_id, status])
  @@map("refill_requests")
}

model Message {
  id                String      @id @default(uuid()) @db.Uuid
  conversation_id   String      @db.Uuid
  appointment_id    String      @db.Uuid
  sender_user_id    String      @db.Uuid
  recipient_user_id String      @db.Uuid
  message_text      String
  message_iv        String
  message_type      MessageType @default(text)
  file_url          String?
  file_type         String?
  file_name         String?
  file_size_bytes   Int?
  is_system_message Boolean     @default(false)
  sent_at           DateTime    @default(now())
  read_at           DateTime?
  deleted_at        DateTime?

  sender    User        @relation("SentMessages", fields: [sender_user_id], references: [id], onDelete: Cascade)
  recipient User        @relation("ReceivedMessages", fields: [recipient_user_id], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointment_id], references: [id])

  @@index([conversation_id, sent_at])
  @@index([appointment_id, sent_at])
  @@map("messages")
}

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  type         String    @db.VarChar(100)
  title        String
  message      String
  action_url   String?
  reference_id String?   @db.Uuid
  read         Boolean   @default(false)
  read_at      DateTime?
  push_sent    Boolean   @default(false)
  sms_sent     Boolean   @default(false)
  group_type   String?   @db.VarChar(50)
  priority     String    @default("normal") @db.VarChar(20)
  expires_at   DateTime?
  image_url    String?
  created_at   DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read, created_at])
  @@index([user_id, group_type, created_at])
  @@index([user_id, priority])
  @@map("notifications")
}

model ConsultationRating {
  id             String   @id @default(uuid()) @db.Uuid
  appointment_id String   @unique @db.Uuid
  patient_id     String   @db.Uuid
  doctor_id      String   @db.Uuid
  rating         Int
  review_text    String?
  created_at     DateTime @default(now())

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  patient     User        @relation("PatientRatings", fields: [patient_id], references: [id], onDelete: Cascade)
  doctor      User        @relation("DoctorRatings", fields: [doctor_id], references: [id], onDelete: Cascade)

  @@map("consultation_ratings")
}

model SymptomAssessment {
  id                  String    @id @default(uuid()) @db.Uuid
  patient_id          String    @db.Uuid
  language            String
  initial_symptoms    String
  conversation        Json
  round_count         Int       @default(0)
  risk_level          String?
  recommended_specialty String?
  final_assessment    String?
  is_complete         Boolean   @default(false)
  booking_initiated   Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  patient User @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@index([patient_id])
  @@map("symptom_assessments")
}

model Pharmacy {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  location        String
  lat             Decimal?       @db.Decimal(10, 7)
  lng             Decimal?       @db.Decimal(10, 7)
  phone           String?
  email           String?
  opening_hours   String?
  license_number  String         @unique
  status          PharmacyStatus @default(PENDING)
  is_partner      Boolean        @default(false)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  last_updated_at DateTime       @default(now())

  admins              PharmacyAdminProfile[]
  hospital_links      HospitalPharmacyLink[]
  dispense_records    DispenseRecord[]
  dispensed_prescriptions Prescription[]

  @@map("pharmacies")
}

model NurseVisitChecklist {
  id              String   @id @default(uuid()) @db.Uuid
  appointment_id  String   @unique @db.Uuid
  items           Json     @default("[]")
  completed_items Json     @default("[]")
  notes           String?
  completed_at    DateTime?
  created_at      DateTime @default(now())

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)

  @@map("nurse_visit_checklists")
}

model DoctorNote {
  id              String   @id @default(uuid()) @db.Uuid
  doctor_id       String   @db.Uuid
  patient_id      String   @db.Uuid
  appointment_id  String?  @db.Uuid
  note_text       String
  is_private      Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  doctor      User        @relation("DoctorNotes", fields: [doctor_id], references: [id], onDelete: Cascade)
  patient     User        @relation("PatientNotes", fields: [patient_id], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  @@index([doctor_id, patient_id])
  @@map("doctor_notes")
}

model ConsultationSummary {
  id                  String      @id @default(uuid()) @db.Uuid
  appointment_id      String      @unique @db.Uuid
  patient_id          String      @db.Uuid
  doctor_id           String      @db.Uuid
  total_messages      Int         @default(0)
  prescription_issued Boolean     @default(false)
  prescription_id     String?
  started_at          DateTime?
  ended_at            DateTime?
  summary_note        String?
  created_at          DateTime    @default(now())

  appointment Appointment @relation(fields: [appointment_id], references: [id])

  @@map("consultation_summaries")
}
